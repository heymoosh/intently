# Copy this file to .env and fill in the anon key.
# EXPO_PUBLIC_ vars are bundled into the JS at build time — only put client-safe
# values here. The Supabase anon key IS designed to be public (RLS gates reads).
# Never put the service_role key in an EXPO_PUBLIC_ var.
#
# Privacy note: the URL and anon key here are intentionally safe to commit.
# Service-role key, OAuth tokens, and Anthropic API key live in Bitwarden
# Secrets Manager only — never in this file.

EXPO_PUBLIC_SUPABASE_URL=https://cjlktjrossrzmswrayfz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=paste-anon-key-here
