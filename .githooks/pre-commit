#!/usr/bin/env bash
# Intently pre-commit hook.
# Hard rule (CLAUDE.md): Bitwarden Secrets Manager is the only allowed secrets
# store. Nothing resembling a secret — or an .env file — ever lands in git.
#
# Enable once per clone:  git config core.hooksPath .githooks
# CI is the source of truth (gitleaks in .github/workflows/security.yml); this
# hook is the local second line of defense so reviewers never see us push a key.

set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$staged" ] && exit 0

fail=0

# 1. Block .env files outright (allow .env.example).
env_hits="$(printf '%s\n' "$staged" | grep -E '(^|/)\.env($|\.)' | grep -v '\.env\.example$' || true)"
if [ -n "$env_hits" ]; then
  echo "pre-commit: refusing to commit .env file(s):" >&2
  printf '  %s\n' $env_hits >&2
  fail=1
fi

# 2. Gitleaks on staged diff if installed; otherwise regex fallback.
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --redact --no-banner; then
    echo "pre-commit: gitleaks flagged a secret in staged changes." >&2
    fail=1
  fi
else
  # Minimal fallback so the hook is useful without gitleaks installed.
  patterns='sk-[A-Za-z0-9]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{10,}\.'
  if git diff --cached -U0 | grep -E "$patterns" >/dev/null; then
    echo "pre-commit: possible secret detected in staged diff (regex fallback)." >&2
    echo "  Install gitleaks for a full scan: brew install gitleaks" >&2
    fail=1
  fi
fi

# 3. Acceptance-criteria creation gate.
# Pairs with CLAUDE.md § "Acceptance criteria authoring rule."
# Blocks commits that stage implementation code under agents/<skill>/ unless
# a non-empty criterion file with at least one '### CR-' entry exists for
# that skill. Deterministic local backstop for Claude-the-model forgetting
# the rule.
seen_skills=""
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    agents/_shared/*) continue ;;
    agents/*/*)
      skill="${f#agents/}"
      skill="${skill%%/*}"
      case " $seen_skills " in *" $skill "*) continue ;; esac
      seen_skills="$seen_skills $skill"
      crit="docs/product/acceptance-criteria/${skill}.md"
      if [ ! -s "$crit" ] || ! grep -q '^### CR-' "$crit"; then
        echo "pre-commit: '$f' is implementation for skill '$skill', but" >&2
        echo "  $crit is missing or has no '### CR-' entries." >&2
        echo "  Run '/derive-criteria $skill' to scaffold from the spec," >&2
        echo "  commit the criterion file in its own PR BEFORE implementation." >&2
        fail=1
      fi
      ;;
  esac
done <<< "$staged"

# 4. CLAUDE.md size cap.
# Hard rule (CLAUDE.md): pointers > content, hard cap 100 lines, soft 75.
# Deterministic local backstop; paired with .github/workflows/docs-check.yml.
# Reads the *staged* blob so unstaged edits don't skew the count.
if printf '%s\n' "$staged" | grep -qx 'CLAUDE.md'; then
  claude_lines=$(git show :CLAUDE.md | wc -l | tr -d ' ')
  if [ "$claude_lines" -gt 100 ]; then
    echo "pre-commit: CLAUDE.md is $claude_lines lines staged (hard cap 100)." >&2
    echo "  Refactor before committing. Rule: pointers > content." >&2
    echo "  Move detail into docs/process/ or docs/architecture/ and link it." >&2
    fail=1
  elif [ "$claude_lines" -gt 75 ]; then
    echo "pre-commit: CLAUDE.md is $claude_lines lines staged (soft 75, hard cap 100)." >&2
    echo "  Non-blocking — consider trimming before the next commit." >&2
  fi
fi

# 5. npm audit on dependency changes.
# Mirrors CI threshold (--audit-level=high). Only runs when app/package.json or
# app/package-lock.json is staged — skips entirely on unrelated commits.
if printf '%s\n' "$staged" | grep -qE '^app/package(-lock)?\.json$'; then
  if command -v npm >/dev/null 2>&1; then
    if ! (cd app && npm audit --audit-level=high --no-fund 2>&1); then
      echo "pre-commit: npm audit found high/critical vulnerabilities in app/." >&2
      echo "  Run 'npm audit --audit-level=high' in app/ for details." >&2
      fail=1
    fi
  else
    echo "pre-commit: npm not found; skipping audit check." >&2
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Commit blocked. See CLAUDE.md (§ 'Acceptance criteria authoring rule'" >&2
  echo "and the Bitwarden secrets rule). Override in a true emergency only:" >&2
  echo "  git commit --no-verify   (don't)" >&2
  exit 1
fi
