{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/*)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/*)",
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/**)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/**)",
      "Write(.claude/routine-output/*)",
      "Edit(.claude/routine-output/*)",
      "Write(.claude/routine-output/**)",
      "Edit(.claude/routine-output/**)",
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/handoffs/*)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/handoffs/*)",
      "Write(.claude/handoffs/*)",
      "Edit(.claude/handoffs/*)",
      "Write(/Users/Muxin/Documents/GitHub/intently/TRACKER.md)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/TRACKER.md)",
      "Write(TRACKER.md)",
      "Edit(TRACKER.md)"
    ],
    "ask": [
      "Bash(git worktree remove --force*)",
      "Bash(git worktree remove -f*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git branch -D*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(git checkout --*)",
      "Bash(git restore --staged*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(supabase db push*)",
      "Bash(supabase db reset*)",
      "Bash(npm uninstall*)",
      "Bash(gh pr close*)",
      "Bash(gh repo delete*)"
    ],
    "additionalDirectories": [
      "/Users/Muxin/Documents/GitHub/intently/.claude/routine-output"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-precheck.sh"
          }
        ]
      }
    ]
  }
}
