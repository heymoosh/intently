{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/*)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/*)",
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/**)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/routine-output/**)",
      "Write(.claude/routine-output/*)",
      "Edit(.claude/routine-output/*)",
      "Write(.claude/routine-output/**)",
      "Edit(.claude/routine-output/**)",
      "Write(/Users/Muxin/Documents/GitHub/intently/.claude/handoffs/*)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/.claude/handoffs/*)",
      "Write(.claude/handoffs/*)",
      "Edit(.claude/handoffs/*)",
      "Write(/Users/Muxin/Documents/GitHub/intently/TRACKER.md)",
      "Edit(/Users/Muxin/Documents/GitHub/intently/TRACKER.md)",
      "Write(TRACKER.md)",
      "Edit(TRACKER.md)"
    ],
    "additionalDirectories": [
      "/Users/Muxin/Documents/GitHub/intently/.claude/routine-output"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-precheck.sh"
          }
        ]
      }
    ]
  }
}
